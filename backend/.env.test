# Application
APP_NAME=AI Muse Blog API Test
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=test

# Server
HOST=0.0.0.0
PORT=8000

# Database - Test database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_muse_blog_test
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Redis - Test database (use different db)
REDIS_URL=redis://localhost:6379/1

# JWT
SECRET_KEY=test-secret-key-for-testing-only
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# File Upload
UPLOAD_DIR=./test_uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/gif","image/webp"]

# Rate Limiting
RATE_LIMIT_ENABLED=False
RATE_LIMIT_PER_MINUTE=100

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=test@example.com
EMAILS_FROM_NAME=AI Muse Blog Test
